<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center"
    android:background="#E3F2FD">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MENU BÀI TẬP LAB 04"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1976D2"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btnMenuCau1"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Câu 1: Shared Preferences (Login)"
        android:layout_marginBottom="10dp"
        android:backgroundTint="#2196F3" />

    <Button
        android:id="@+id/btnMenuCau2"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Câu 2: Internal Storage"
        android:layout_marginBottom="10dp"
        android:backgroundTint="#2196F3" />

    <Button
        android:id="@+id/btnMenuCau3"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Câu 3: External Storage"
        android:layout_marginBottom="10dp"
        android:backgroundTint="#2196F3" />

    <Button
        android:id="@+id/btnMenuCau4"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Câu 4: SQLite Login/Register"
        android:layout_marginBottom="10dp"
        android:backgroundTint="#2196F3" />

    <Button
        android:id="@+id/btnMenuCau4_1"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Câu 4.1: Quản Lý Lớp Học"
        android:backgroundTint="#673AB7" />

</LinearLayout>